# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=crypto-prices
KAFKA_CONSUMER_GROUP=smart-consumer-group

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=cryptodb
POSTGRES_USER=crypto
POSTGRES_PASSWORD=crypto123

# Producer
FETCH_INTERVAL_SECONDS=15
COINGECKO_COINS=bitcoin,ethereum,solana

# Spike Detection
SPIKE_WINDOW_SIZE=10
SPIKE_THRESHOLD_PCT=0.5

# Logging — LOG_FORMAT: "console" (dev) or "json" (prod)
LOG_LEVEL=INFO
LOG_FORMAT=console

# Metrics (Prometheus scrape endpoints)
PRODUCER_METRICS_PORT=8000
CONSUMER_METRICS_PORT=8001
